# Produktions-Konfiguration für all-inkl (dat.aral-welle.com)
# Auf dem Server zu .env kopieren, Werte ausfüllen, dann: php artisan key:generate

APP_NAME="Digitaler Pendelordner"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dat.aral-welle.com

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Datenbank (aus dem all-inkl KAS: Datenbank anlegen) ---------------------
# Host ist bei all-inkl i. d. R. "localhost"; Name/User beginnen mit d0XXXXXX
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=DEINE_DB
DB_USERNAME=DEIN_DB_USER
DB_PASSWORD=DEIN_DB_PASSWORT

# --- Sessions/Cache/Queue über die Datenbank (kein Redis auf Shared Hosting) -
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Belegarchiv -------------------------------------------------------------
BELEGE_DISK=belege

# --- OCR ---------------------------------------------------------------------
# Tesseract ist auf Shared Hosting meist NICHT verfügbar -> Bild-OCR aus.
# PDF-Text-Extraktion (smalot/pdfparser) funktioniert unabhängig davon.
TESSERACT_PATH=
TESSERACT_LANG=deu

# --- FinTS (Bankabruf) -------------------------------------------------------
FINTS_PRODUCT_REGISTRATION=
FINTS_PRODUCT_VERSION=1.0
BANK_FETCH_TIME=06:00

# --- Mail-Eingang (optional, IMAP) ------------------------------------------
MAIL_INGEST_ENABLED=false
MAIL_INGEST_HOST=
MAIL_INGEST_PORT=993
MAIL_INGEST_ENCRYPTION=ssl
MAIL_INGEST_USERNAME=
MAIL_INGEST_PASSWORD=
MAIL_INGEST_FOLDER=INBOX
MAIL_INGEST_BUSINESS_ID=

# --- Mailversand (all-inkl SMTP, optional für Benachrichtigungen) ------------
MAIL_MAILER=smtp
MAIL_HOST=DEIN_KAS_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=DEIN_MAIL_USER
MAIL_PASSWORD=DEIN_MAIL_PASSWORT
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="pendelordner@aral-welle.com"
MAIL_FROM_NAME="${APP_NAME}"
